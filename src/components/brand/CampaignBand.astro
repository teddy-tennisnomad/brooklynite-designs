---
type Props = {
  title: string;
  copy: string;
  href?: string;
  label?: string;
};

const { title, copy, href = "/campaigns/bring-brooklyn-back", label = "Explore the campaign" } = Astro.props;
---

<section class="bg-asphalt text-white">
  <div class="container-shell grid gap-8 py-14 md:grid-cols-[0.9fr_1.1fr] md:items-center">
    <div>
      <p class="text-xs font-black uppercase tracking-[0.24em] text-taxi">Campaign</p>
      <h2 class="mt-3 font-editorial text-4xl font-black leading-tight sm:text-5xl">{title}</h2>
    </div>
    <div>
      <p class="text-lg leading-8 text-white/74">{copy}</p>
      <a class="focus-ring mt-6 inline-flex rounded-md bg-taxi px-5 py-3 text-sm font-black uppercase tracking-[0.12em] text-asphalt hover:bg-white" href={href}>{label}</a>
    </div>
  </div>
</section>
