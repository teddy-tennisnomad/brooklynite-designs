---
type Props = {
  kicker?: string;
  title: string;
  copy: string;
  ctaHref?: string;
  ctaLabel?: string;
};

const { kicker, title, copy, ctaHref, ctaLabel } = Astro.props;
---

<section class="grid gap-5">
  {kicker && <p class="heritage-kicker">{kicker}</p>}
  <h2 class="font-editorial text-4xl font-black leading-tight text-asphalt sm:text-5xl">{title}</h2>
  <p class="max-w-3xl text-lg leading-8 text-ink/72">{copy}</p>
  {ctaHref && ctaLabel && (
    <a class="focus-ring inline-flex w-fit rounded-md bg-asphalt px-5 py-3 text-sm font-black uppercase tracking-[0.12em] text-white hover:bg-brick" href={ctaHref}>{ctaLabel}</a>
  )}
</section>
