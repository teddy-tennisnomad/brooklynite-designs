---
type Props = {
  title?: string;
  story: string;
  location?: string;
};

const { title = "Why this piece exists", story, location } = Astro.props;
---

<section class="rounded-lg border border-brick/18 bg-cream p-5">
  <p class="heritage-kicker">{title}</p>
  <p class="mt-3 text-base leading-7 text-ink/76">{story}</p>
  {location && <p class="mt-4 text-sm font-bold text-brick">Inspired by {location}</p>}
</section>
