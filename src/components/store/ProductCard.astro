---
import type { Product } from "@/data/products";
import { formatPrice, productPrice } from "@/data/products";

type Props = { product: Product };
const { product } = Astro.props;
---

<article class="group overflow-hidden rounded-lg border border-ink/10 bg-white shadow-sm transition hover:-translate-y-0.5 hover:shadow-soft">
  <a href={`/products/${product.slug}`} class="focus-ring block">
    <div class="aspect-[4/3] overflow-hidden" style={`background:${product.color}`}>
      <img class="h-full w-full object-cover transition duration-500 group-hover:scale-105" src={product.image} alt={product.title} loading="lazy" />
    </div>
    <div class="grid gap-3 p-4">
      <div class="flex items-start justify-between gap-3">
        <div>
          <h3 class="font-semibold text-ink">{product.title}</h3>
          <p class="mt-1 text-sm text-ink/60">{product.subtitle}</p>
        </div>
        <p class="shrink-0 text-sm font-bold text-harbor">{formatPrice(productPrice(product))}</p>
      </div>
      <div class="flex flex-wrap gap-2">
        {product.themes.slice(0, 2).map((theme) => <span class="rounded-full bg-ink/[0.06] px-2.5 py-1 text-xs font-semibold text-ink/65">{theme}</span>)}
      </div>
    </div>
  </a>
</article>
