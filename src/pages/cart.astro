---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Cart | Brooklynite Designs">
  <section class="container-shell py-16">
    <h1 class="font-display text-5xl font-semibold">Cart</h1>
    <p class="mt-4 max-w-2xl text-lg leading-8 text-ink/70">Use the cart button in the header to review items and continue to checkout.</p>
    <a class="focus-ring mt-8 inline-flex min-h-12 items-center rounded-md bg-harbor px-6 py-3 font-bold text-white hover:bg-denim" href="/collections">Continue shopping</a>
  </section>
</BaseLayout>
