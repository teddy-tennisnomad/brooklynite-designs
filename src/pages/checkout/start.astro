---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Checkout | Brooklynite Designs">
  <section class="container-shell py-16">
    <div class="max-w-2xl rounded-lg border border-ink/10 bg-white p-8 shadow-sm">
      <p class="text-sm font-bold uppercase tracking-[0.18em] text-brick">Checkout handoff</p>
      <h1 class="mt-3 font-display text-4xl font-semibold">Stripe Checkout endpoint placeholder</h1>
      <p class="mt-4 leading-7 text-ink/70">This route is ready to become the Cloud Run checkout starter. The cart currently stores line items in local storage; the next step is posting those lines to an API that validates product prices, creates a Stripe Checkout Session, and redirects the shopper.</p>
      <a class="focus-ring mt-7 inline-flex min-h-12 items-center rounded-md bg-harbor px-6 py-3 font-bold text-white hover:bg-denim" href="/collections">Back to shop</a>
    </div>
  </section>
</BaseLayout>
