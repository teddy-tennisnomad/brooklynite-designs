---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Shipping & Returns | Brooklynite Designs">
  <section class="container-shell py-16">
    <h1 class="font-display text-5xl font-semibold">Shipping & returns</h1>
    <div class="mt-8 grid gap-5 md:grid-cols-3">
      {[
        ["Shipping", "Orders are packed in-house. Launch copy should include current processing windows and carrier options."],
        ["Gifts", "Gift notes and bundles are part of the planned checkout flow, with clear recipient-friendly packing."],
        ["Returns", "Final policy copy should clarify exchanges, handmade items, sale items, and damaged shipment support."]
      ].map(([title, copy]) => (
        <section class="rounded-lg border border-ink/10 bg-white p-5 shadow-sm">
          <h2 class="font-display text-2xl font-semibold">{title}</h2>
          <p class="mt-3 leading-7 text-ink/70">{copy}</p>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
