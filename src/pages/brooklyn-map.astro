---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BrooklynMapPreview from "@/components/map/BrooklynMapPreview.astro";
import { mapLocations } from "@/data/community";
---

<BaseLayout title="Brooklyn Map | Brooklynite Designs" description="Explore Brooklynite stories, events, products, and neighborhood inspiration points across Brooklyn.">
  <section class="container-shell py-12">
    <p class="heritage-kicker">Community map</p>
    <h1 class="mt-3 font-editorial text-5xl font-black text-asphalt">Shop the borough. Read the borough. Visit the borough.</h1>
    <p class="mt-5 max-w-3xl text-lg leading-8 text-ink/72">This is the first version of the Brooklynite map: a branded layer connecting products, articles, events, and neighborhood memory. The next implementation can make each marker fully interactive.</p>
  </section>
  <section class="container-shell">
    <BrooklynMapPreview />
  </section>
  <section class="container-shell py-12">
    <div class="grid gap-4 md:grid-cols-2">
      {mapLocations.map((location) => (
        <article id={location.slug} class="rounded-lg border border-asphalt/10 bg-white p-5 shadow-sm">
          <p class="text-xs font-black uppercase tracking-[0.18em] text-steel">{location.neighborhood} / {location.type}</p>
          <h2 class="mt-2 font-editorial text-2xl font-black text-asphalt">{location.title}</h2>
          <p class="mt-3 leading-7 text-ink/70">{location.summary}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
