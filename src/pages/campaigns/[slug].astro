---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProductGrid from "@/components/store/ProductGrid.astro";
import EditorialCard from "@/components/brand/EditorialCard.astro";
import { articles, campaigns } from "@/data/community";
import { products } from "@/data/products";

export function getStaticPaths() {
  return campaigns.map((campaign) => ({ params: { slug: campaign.slug }, props: { campaign } }));
}

const { campaign } = Astro.props;
const campaignProducts = products.filter((product) => campaign.productIds.includes(product.id));
const campaignArticles = articles.filter((article) => campaign.articleIds.includes(article.id));
---

<BaseLayout title={`${campaign.title} | Brooklynite Designs`} description={campaign.dek}>
  <section class="bg-asphalt text-white">
    <div class="container-shell py-16">
      <p class="text-xs font-black uppercase tracking-[0.24em] text-taxi">Campaign</p>
      <h1 class="mt-3 max-w-4xl font-editorial text-6xl font-black leading-tight">{campaign.title}</h1>
      <p class="mt-5 max-w-2xl text-xl leading-8 text-white/74">{campaign.dek}</p>
    </div>
  </section>
  <section class="container-shell py-12">
    <h2 class="mb-6 font-editorial text-3xl font-black">Capsule products</h2>
    <ProductGrid products={campaignProducts} />
  </section>
  <section class="container-shell py-12">
    <h2 class="mb-6 font-editorial text-3xl font-black">Campaign stories</h2>
    <div class="grid gap-5 md:grid-cols-3">
      {campaignArticles.map((article) => (
        <EditorialCard eyebrow={article.category.replaceAll("-", " ")} title={article.title} copy={article.dek} href={`/articles/${article.slug}`} />
      ))}
    </div>
  </section>
</BaseLayout>
