---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { events, findMapLocation } from "@/data/community";

export function getStaticPaths() {
  return events.map((event) => ({ params: { slug: event.slug }, props: { event } }));
}

const { event } = Astro.props;
const location = findMapLocation(event.mapLocationId);
---

<BaseLayout title={`${event.title} | Brooklynite Designs`} description={event.dek}>
  <section class="container-shell py-12">
    <p class="heritage-kicker">{event.dateLabel}</p>
    <h1 class="mt-3 max-w-4xl font-editorial text-5xl font-black leading-tight text-asphalt">{event.title}</h1>
    <p class="mt-5 max-w-3xl text-xl leading-8 text-ink/72">{event.dek}</p>
    <div class="mt-8 rounded-lg border border-asphalt/10 bg-white p-6 shadow-sm">
      <p class="font-bold text-asphalt">{event.locationLabel}</p>
      {location && <p class="mt-2 text-ink/70">Map connection: {location.title}, {location.neighborhood}</p>}
      <p class="mt-5 leading-8 text-ink/74">This event route is scaffolded for future pop-up, drop, and community event content.</p>
    </div>
  </section>
</BaseLayout>
