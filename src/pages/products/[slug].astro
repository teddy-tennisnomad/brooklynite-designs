---
import AddToCart from "@/components/cart/AddToCart";
import ProductGrid from "@/components/store/ProductGrid.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { findProduct, formatPrice, productPrice, products } from "@/data/products";

export function getStaticPaths() {
  return products.map((product) => ({ params: { slug: product.slug } }));
}

const product = findProduct(Astro.params.slug ?? "");
if (!product) return Astro.redirect("/collections");

const related = products.filter((item) => item.id !== product.id && item.recipient.some((recipient) => product.recipient.includes(recipient))).slice(0, 3);
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: product.title,
  description: product.descriptionShort,
  image: new URL(product.image, Astro.site).toString(),
  offers: {
    "@type": "Offer",
    priceCurrency: "USD",
    price: (productPrice(product) / 100).toFixed(2),
    availability: "https://schema.org/InStock"
  }
};
---

<BaseLayout title={`${product.title} | Brooklynite Designs`} description={product.descriptionShort}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <section class="container-shell grid gap-10 py-12 lg:grid-cols-[1.05fr_0.95fr]">
    <div class="overflow-hidden rounded-lg border border-ink/10 bg-white shadow-sm">
      <img class="aspect-square w-full object-cover" src={product.image} alt={product.title} />
    </div>
    <div>
      <a class="focus-ring text-sm font-bold text-harbor hover:text-denim" href="/collections">Back to shop</a>
      <h1 class="mt-5 font-display text-5xl font-semibold leading-tight">{product.title}</h1>
      <p class="mt-3 text-xl text-ink/65">{product.subtitle}</p>
      <p class="mt-5 text-2xl font-bold text-harbor">{formatPrice(productPrice(product))}</p>
      <p class="mt-6 text-lg leading-8 text-ink/72">{product.descriptionShort}</p>
      <div class="mt-7">
        <AddToCart product={product} client:load />
      </div>
      <div class="mt-8 grid gap-4 border-y border-ink/10 py-6 sm:grid-cols-3">
        <div><strong class="block">Stock</strong><span class="text-sm text-ink/62">Ready to ship or made to order</span></div>
        <div><strong class="block">Fulfillment</strong><span class="text-sm text-ink/62">Packed in-house</span></div>
        <div><strong class="block">Checkout</strong><span class="text-sm text-ink/62">Stripe-ready flow</span></div>
      </div>
      <div class="mt-8 grid gap-6">
        <section>
          <h2 class="font-display text-2xl font-semibold">Details</h2>
          <p class="mt-3 leading-7 text-ink/70">{product.descriptionLong}</p>
        </section>
        <section>
          <h2 class="font-display text-2xl font-semibold">Materials & Care</h2>
          <ul class="mt-3 grid gap-2 text-ink/70">
            {product.materials.map((material) => <li>{material}</li>)}
          </ul>
          <p class="mt-3 text-ink/70">{product.care}</p>
        </section>
      </div>
    </div>
  </section>
  {related.length > 0 && (
    <section class="container-shell py-10">
      <h2 class="mb-6 font-display text-3xl font-semibold">Related picks</h2>
      <ProductGrid products={related} />
    </section>
  )}
</BaseLayout>
