---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Contact | Brooklynite Designs">
  <section class="container-shell py-16">
    <div class="max-w-2xl">
      <p class="text-sm font-bold uppercase tracking-[0.18em] text-harbor">Contact</p>
      <h1 class="mt-3 font-display text-5xl font-semibold">Need help with an order or gift?</h1>
      <p class="mt-5 text-lg leading-8 text-ink/70">Add the production email or contact form integration here. For launch, this page can connect to Resend or a lightweight Cloud Run form handler.</p>
      <a class="focus-ring mt-8 inline-flex min-h-12 items-center rounded-md bg-harbor px-6 py-3 font-bold text-white hover:bg-denim" href="mailto:hello@brooklynitedesigns.com">Email the shop</a>
    </div>
  </section>
</BaseLayout>
