---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProductGrid from "@/components/store/ProductGrid.astro";
import { collections, products } from "@/data/products";

const featured = products.filter((product) => product.featured);
---

<BaseLayout title="Brooklynite Designs | Brooklyn Gifts, Apparel & Baby Goods">
  <section class="container-shell grid min-h-[calc(100vh-64px)] items-center gap-10 py-10 lg:grid-cols-[0.92fr_1.08fr]">
    <div class="max-w-2xl">
      <p class="text-sm font-bold uppercase tracking-[0.18em] text-brick">Family-run in Brooklyn</p>
      <h1 class="mt-5 font-display text-5xl font-semibold leading-[1.02] text-ink sm:text-6xl lg:text-7xl">Brooklynite Designs</h1>
      <p class="mt-6 max-w-xl text-lg leading-8 text-ink/70">Brooklyn-inspired apparel, baby gifts, hats, knits, art, and accessories made for thoughtful gifting and everyday borough pride.</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="focus-ring inline-flex min-h-12 items-center rounded-md bg-harbor px-6 py-3 font-bold text-white hover:bg-denim" href="/collections">Shop all</a>
        <a class="focus-ring inline-flex min-h-12 items-center rounded-md border border-ink/15 bg-white px-6 py-3 font-bold text-ink hover:border-harbor hover:text-harbor" href="/collections/baby-gifts">Baby gifts</a>
      </div>
      <div class="mt-9 grid max-w-xl grid-cols-3 gap-4 text-sm text-ink/65">
        <div><strong class="block text-ink">Printed locally</strong> Brooklyn production partners</div>
        <div><strong class="block text-ink">Gift-ready</strong> Easy bundles and notes</div>
        <div><strong class="block text-ink">In-house care</strong> Packed by family</div>
      </div>
    </div>
    <div class="relative">
      <img class="aspect-[5/4] w-full rounded-lg object-cover shadow-soft" src="/images/products/hero-product.png" alt="Brooklyn-inspired apparel and baby gift products" />
    </div>
  </section>

  <section class="bg-white py-16">
    <div class="container-shell">
      <div class="mb-8 flex flex-col justify-between gap-4 sm:flex-row sm:items-end">
        <div>
          <p class="text-sm font-bold uppercase tracking-[0.18em] text-harbor">Start shopping</p>
          <h2 class="mt-2 font-display text-4xl font-semibold">Collections built around gifts</h2>
        </div>
        <a class="focus-ring font-bold text-harbor hover:text-denim" href="/collections">View all collections</a>
      </div>
      <div class="grid gap-4 md:grid-cols-4">
        {collections.map((collection) => (
          <a class="focus-ring rounded-lg border border-ink/10 bg-paper p-5 transition hover:-translate-y-0.5 hover:shadow-soft" href={`/collections/${collection.slug}`}>
            <h3 class="font-display text-2xl font-semibold">{collection.title}</h3>
            <p class="mt-3 text-sm leading-6 text-ink/65">{collection.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="container-shell py-16">
    <div class="mb-8 flex flex-col justify-between gap-4 sm:flex-row sm:items-end">
      <div>
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-brick">Featured</p>
        <h2 class="mt-2 font-display text-4xl font-semibold">Small-batch favorites</h2>
      </div>
      <a class="focus-ring font-bold text-harbor hover:text-denim" href="/search">Search the shop</a>
    </div>
    <ProductGrid products={featured} />
  </section>

  <section class="bg-ink py-16 text-white">
    <div class="container-shell grid gap-8 md:grid-cols-[1fr_1.2fr] md:items-center">
      <h2 class="font-display text-4xl font-semibold">Warm, local, and ready for launch.</h2>
      <p class="text-lg leading-8 text-white/72">This scaffold keeps the public storefront static and fast while leaving clean handoff points for Firestore catalog data, inventory, and Stripe Checkout.</p>
    </div>
  </section>
</BaseLayout>
