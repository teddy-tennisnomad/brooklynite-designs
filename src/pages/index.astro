---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CampaignBand from "@/components/brand/CampaignBand.astro";
import EditorialCard from "@/components/brand/EditorialCard.astro";
import HeritageBadge from "@/components/brand/HeritageBadge.astro";
import StoryBlock from "@/components/brand/StoryBlock.astro";
import BrooklynMapPreview from "@/components/map/BrooklynMapPreview.astro";
import ProductGrid from "@/components/store/ProductGrid.astro";
import { collections, products } from "@/data/products";
import { articles, events } from "@/data/community";

const heritageProducts = products.filter((product) => product.capsule === "bring-brooklyn-back");
const featuredArticle = articles.find((article) => article.featured);
const featuredEvent = events.find((event) => event.featured);
---

<BaseLayout title="Brooklynite Designs | Brooklyn Tradition Carried Forward" description="Brooklynite Designs is a premium Brooklyn heritage brand established in 2016, rooted in Polish immigrant family memory and borough icons.">
  <section class="container-shell grid min-h-[calc(100vh-72px)] items-center gap-10 py-10 lg:grid-cols-[0.92fr_1.08fr]">
    <div class="max-w-2xl">
      <p class="heritage-kicker">Established 2016</p>
      <h1 class="mt-5 font-brand text-5xl font-black leading-[1.02] text-asphalt sm:text-6xl lg:text-7xl">Brooklyn tradition, carried forward.</h1>
      <p class="mt-6 max-w-xl text-lg leading-8 text-ink/72">A premium Brooklyn heritage brand rooted in Polish immigrant family memory, neighborhood pride, and the everyday icons that made New York feel alive.</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="focus-ring inline-flex min-h-12 items-center rounded-md bg-asphalt px-6 py-3 text-sm font-black uppercase tracking-[0.12em] text-white hover:bg-brick" href="/collections/heritage-icons">Shop icons</a>
        <a class="focus-ring inline-flex min-h-12 items-center rounded-md border border-asphalt/15 bg-white px-6 py-3 text-sm font-black uppercase tracking-[0.12em] text-asphalt hover:border-brick hover:text-brick" href="/brooklyn-map">Explore map</a>
      </div>
      <div class="mt-9 flex flex-wrap gap-2">
        <HeritageBadge label="Polish immigrant roots" />
        <HeritageBadge label="Brooklyn icons" tone="navy" />
        <HeritageBadge label="Community map" tone="taxi" />
      </div>
    </div>
    <div class="relative">
      <img class="aspect-[5/4] w-full rounded-lg object-cover shadow-soft" src="/images/products/hero-product.png" alt="Brooklyn-inspired apparel and baby gift products" />
      <div class="absolute -bottom-6 left-6 right-6 rounded-md bg-white p-4 shadow-soft sm:right-auto sm:w-80">
        <p class="heritage-kicker">Bring Brooklyn Back</p>
        <p class="mt-2 text-sm leading-6 text-ink/72">Bridge shirts, baseball heritage caps, taxi graphics, baby gifts, and stories from the borough that shaped the family.</p>
      </div>
    </div>
  </section>

  <section class="bg-white py-16">
    <div class="container-shell">
      <StoryBlock
        kicker="Origin story"
        title="Built from a family story that started before Brooklyn became a global brand."
        copy="The deeper Brooklynite story begins with Polish immigrants arriving in New York City in the early 1990s. They watched a gritty, working city transform around them, and Brooklynite exists to preserve the emotional texture of that earlier Brooklyn while making it premium, wearable, and alive now."
        ctaHref="/about"
        ctaLabel="Read the story"
      />
    </div>
  </section>

  <section class="container-shell py-16">
    <div class="mb-8 flex flex-col justify-between gap-4 sm:flex-row sm:items-end">
      <div>
        <p class="heritage-kicker">Heritage icons</p>
        <h2 class="mt-2 font-editorial text-4xl font-black text-asphalt">The symbols that made Brooklyn feel like Brooklyn.</h2>
      </div>
      <a class="focus-ring font-black text-brick hover:text-asphalt" href="/collections/heritage-icons">Shop heritage icons</a>
    </div>
    <ProductGrid products={heritageProducts} />
  </section>

  <section class="bg-white py-16">
    <div class="container-shell">
      <div class="mb-8 flex flex-col justify-between gap-4 sm:flex-row sm:items-end">
        <div>
          <p class="heritage-kicker">Shop by intent</p>
          <h2 class="mt-2 font-editorial text-4xl font-black text-asphalt">Collections built around memory and gifting.</h2>
        </div>
        <a class="focus-ring font-black text-brick hover:text-asphalt" href="/collections">View all collections</a>
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        {collections.map((collection) => (
          <a class="focus-ring rounded-lg border border-asphalt/10 bg-paper p-5 transition hover:-translate-y-0.5 hover:shadow-soft" href={`/collections/${collection.slug}`}>
            <h3 class="font-editorial text-2xl font-black">{collection.title}</h3>
            <p class="mt-3 text-sm leading-6 text-ink/65">{collection.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="container-shell py-16">
    <BrooklynMapPreview />
  </section>

  <CampaignBand title="Bring Brooklyn Back" copy="Brooklyn changed. The feeling does not have to disappear. This first campaign ties bridge views, taxi yellow, baseball memory, baby gifts, and immigrant family history into one premium Brooklyn world." />

  <section class="container-shell py-16">
    <div class="mb-8 flex flex-col justify-between gap-4 sm:flex-row sm:items-end">
      <div>
        <p class="heritage-kicker">Community</p>
        <h2 class="mt-2 font-editorial text-4xl font-black text-asphalt">Stories and events that bring people back.</h2>
      </div>
      <a class="focus-ring font-black text-brick hover:text-asphalt" href="/articles">Read articles</a>
    </div>
    <div class="grid gap-5 md:grid-cols-2">
      {featuredArticle && <EditorialCard eyebrow="Article" title={featuredArticle.title} copy={featuredArticle.dek} href={`/articles/${featuredArticle.slug}`} />}
      {featuredEvent && <EditorialCard eyebrow={featuredEvent.dateLabel} title={featuredEvent.title} copy={featuredEvent.dek} href={`/events/${featuredEvent.slug}`} />}
    </div>
  </section>
</BaseLayout>
