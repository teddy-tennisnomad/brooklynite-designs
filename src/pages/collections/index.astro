---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProductGrid from "@/components/store/ProductGrid.astro";
import { collections, products } from "@/data/products";
---

<BaseLayout title="Collections | Brooklynite Designs">
  <section class="container-shell py-12">
    <p class="text-sm font-bold uppercase tracking-[0.18em] text-harbor">Shop</p>
    <h1 class="mt-3 font-display text-5xl font-semibold">Collections</h1>
    <p class="mt-4 max-w-2xl text-lg leading-8 text-ink/70">Browse by recipient, product type, price point, and gift moment.</p>
    <div class="mt-8 grid gap-4 md:grid-cols-4">
      {collections.map((collection) => (
        <a class="focus-ring rounded-lg border border-ink/10 bg-white p-5 shadow-sm hover:shadow-soft" href={`/collections/${collection.slug}`}>
          <h2 class="font-display text-2xl font-semibold">{collection.title}</h2>
          <p class="mt-3 text-sm leading-6 text-ink/65">{collection.description}</p>
        </a>
      ))}
    </div>
  </section>
  <section class="container-shell py-8">
    <h2 class="mb-6 font-display text-3xl font-semibold">All products</h2>
    <ProductGrid products={products} />
  </section>
</BaseLayout>
