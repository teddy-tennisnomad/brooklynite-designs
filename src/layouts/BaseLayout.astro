---
import "../styles/global.css";
import CartDrawer from "@/components/cart/CartDrawer";
import BrickLogo from "@/components/brand/BrickLogo.astro";

type Props = {
  title?: string;
  description?: string;
};

const {
  title = "Brooklynite Designs",
  description = "Brooklynite Designs is a premium Brooklyn heritage brand established in 2016, rooted in immigrant family memory and neighborhood tradition."
} = Astro.props;

const nav = [
  { href: "/collections", label: "Shop" },
  { href: "/collections/heritage-icons", label: "Heritage Icons" },
  { href: "/brooklyn-map", label: "Map" },
  { href: "/articles", label: "Articles" },
  { href: "/about", label: "Story" }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
  </head>
  <body>
    <a class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:bg-paper focus:px-4 focus:py-2" href="#main">Skip to content</a>
    <header class="sticky top-0 z-40 border-b border-asphalt/10 bg-paper/94 backdrop-blur">
      <div class="container-shell flex min-h-[72px] items-center justify-between gap-5">
        <a href="/" class="focus-ring">
          <BrickLogo />
        </a>
        <nav class="hidden items-center gap-7 text-sm font-semibold text-ink/75 md:flex" aria-label="Main navigation">
          {nav.map((item) => <a class="focus-ring hover:text-ink" href={item.href}>{item.label}</a>)}
        </nav>
        <div class="flex items-center gap-2">
          <a class="focus-ring hidden rounded-full border border-asphalt/15 bg-white px-4 py-2 text-sm font-black text-asphalt hover:border-brick hover:text-brick sm:inline-flex" href="/search">Search</a>
          <CartDrawer client:load />
        </div>
      </div>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="mt-20 border-t border-asphalt/10 bg-white">
      <div class="container-shell grid gap-10 py-12 md:grid-cols-[1.4fr_1fr_1fr_1fr]">
        <div>
          <BrickLogo />
          <p class="mt-4 max-w-md text-sm leading-6 text-ink/68">Established in 2016 and built from a family story that reaches back to Polish immigrants arriving in New York in the early 90s.</p>
        </div>
        <div>
          <p class="text-sm font-black uppercase tracking-wide text-ink/50">Shop</p>
          <div class="mt-4 grid gap-2 text-sm text-ink/70">
            <a href="/collections">All collections</a>
            <a href="/collections/heritage-icons">Heritage icons</a>
            <a href="/collections/baby-gifts">Baby gifts</a>
          </div>
        </div>
        <div>
          <p class="text-sm font-black uppercase tracking-wide text-ink/50">Community</p>
          <div class="mt-4 grid gap-2 text-sm text-ink/70">
            <a href="/brooklyn-map">Brooklyn map</a>
            <a href="/articles">Articles</a>
            <a href="/events">Events</a>
          </div>
        </div>
        <div>
          <p class="text-sm font-black uppercase tracking-wide text-ink/50">Help</p>
          <div class="mt-4 grid gap-2 text-sm text-ink/70">
            <a href="/contact">Contact</a>
            <a href="/faq">FAQ</a>
            <a href="/shipping-returns">Shipping & returns</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
